# .env
NUXT_SESSION_PASSWORD=

# Site URL (used for sitemap, OG images, canonical URLs)
NUXT_PUBLIC_SITE_URL=https://zimablue.cc

# Dev server port (default: 3000)
# PORT=3001
# TMPDIR=/tmp  # Required on macOS for Nuxt 4 dev server
ADMIN_USERNAME=
ADMIN_PASSWORD=
USER_PASSWORD=

# Social OAuth (Meta App for Facebook + Instagram, separate App for Threads)
NUXT_META_APP_ID=
NUXT_META_APP_SECRET=
NUXT_THREADS_APP_ID=
NUXT_THREADS_APP_SECRET=

NUXT_BLUSKY_APP_SECRET=
